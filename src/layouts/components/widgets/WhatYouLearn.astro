---
interface Props {
  items: string[];
  title?: string;
}

const { items, title = "What you'll learn" } = Astro.props;
---

<div class="my-6 p-5 bg-blue-50 dark:bg-slate-800 border border-blue-200 dark:border-slate-600 rounded-xl not-prose">
  <p class="font-semibold text-blue-900 dark:text-blue-300 mb-3 flex items-center gap-2 text-base">
    <span>📋</span> {title}
  </p>
  <ul class="space-y-2 m-0 p-0 list-none">
    {items.map((item: string) => (
      <li class="flex items-start gap-2 text-sm text-slate-700 dark:text-slate-300">
        <span class="text-blue-500 mt-0.5 font-bold flex-shrink-0">✓</span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>